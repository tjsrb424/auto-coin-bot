APP_ENV=development
RUNTIME_INSTANCE_ID=
RUNTIME_LOCK_TTL_SECONDS=3600
ALLOW_DEV_LIVE_TRADING=false
EXCHANGE=upbit
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=
BITHUMB_FORCE_IPV4=true
LIVE_TRADING_ENABLED=false
MAX_LIVE_ORDER_KRW=30000
MAX_DAILY_LIVE_LOSS_PERCENT=1
MIN_LIVE_ORDER_KRW=5000
MAX_LIVE_POSITION_RATIO=0.5
LIVE_DUPLICATE_WINDOW_SECONDS=30
LIVE_FEE_RATE=0.0005
LIVE_VOLATILITY_BLOCK_RATE=0.03
LIVE_MIN_CANDLE_VOLUME=0
LIVE_AUTO_TRADING_ENABLED=false
AUTO_PILOT_ENABLED=false
AUTO_STRATEGY_PILOT_ENABLED=false
SMART_AUTONOMOUS_TRADING_ENABLED=false
AUTO_ALLOWED_EXCHANGE=bithumb
AUTO_ALLOWED_MARKET=KRW-BTC
AUTO_ALLOWED_ORDER_TYPE=limit
AUTO_MIN_ORDER_KRW=10000
AUTO_MAX_ORDER_KRW=30000
AUTO_MAX_ORDERS_PER_DAY=0
AUTO_PILOT_MAX_ORDERS_PER_DAY=0
AUTO_MAX_OPEN_POSITION_COUNT=1
AUTO_ORDER_TYPE=limit
AUTO_BUY_PRICE_OFFSET_PERCENT=3
AUTO_ENTRY_PRICE_OFFSET_PERCENT=0.3
AUTO_CANCEL_AFTER_SECONDS=60
AUTO_CANCEL_UNFILLED_AFTER_SECONDS=60
AUTO_COOLDOWN_SECONDS=1800
AUTO_REQUIRE_COMPLETED_CANDLE=true
AUTO_STOP_LOSS_PERCENT=0.7
AUTO_TAKE_PROFIT_PERCENT=1.0
AUTO_MAX_HOLD_MINUTES=60
AUTO_EXIT_ENABLED=true
AUTO_EXIT_ORDER_TYPE=limit
AUTO_MARKET_ORDER_ENABLED=false
AUTO_EXIT_PRICE_OFFSET_PERCENT=0.2
AUTO_CANCEL_EXIT_ORDER_AFTER_SECONDS=60
AUTO_MAX_EXIT_RETRY_COUNT=1
AUTO_EXIT_REQUIRE_MANUAL_CONFIRM=true

# Smart Engine defaults stay safe in local/dev environments.
# SMART_ENGINE_LIVE_MODE=shadow records decisions only.
# SMART_ENGINE_LIVE_MODE=limited allows small Smart Engine live orders.
# SMART_ENGINE_LIVE_MODE=live or autonomous_live allows Smart order_intent live orders.
SMART_ENGINE_SHADOW_MODE=true
SMART_ENGINE_LIVE_MODE=shadow
SMART_AUTONOMOUS_CANDLE_UNIT=5
SMART_MIN_REBALANCE_DELTA_KRW=10000
SMART_MIN_REBALANCE_DELTA_PCT=5
SMART_REHEARSAL_MAX_DAILY_ORDERS=1
SMART_REHEARSAL_MIN_ORDER_KRW=10000
SMART_REHEARSAL_MAX_RISK_SCORE=60
SMART_REHEARSAL_ALLOWED_START_HOUR_KST=9
SMART_REHEARSAL_ALLOWED_END_HOUR_KST=23
SMART_EXTERNAL_TIMEOUT_SECONDS=2.5
SMART_EXTERNAL_USD_KRW_RATE=1350
SMART_EXCHANGE_NOTICE_URL=https://global-docs.upbit.com/changelog
SMART_NEWS_PROVIDER_URL=

RISK_MAX_DAILY_LOSS_PERCENT=20
RISK_MAX_DAILY_LOSS_KRW=10000
RISK_ACCOUNT_EQUITY_KRW=300000
RISK_MAX_ORDERS_PER_DAY=0
RISK_MAX_ENTRY_ORDERS_PER_DAY=0
RISK_MAX_EXIT_ORDERS_PER_DAY=3
RISK_MAX_CONSECUTIVE_LOSSES=2
RISK_MIN_COOLDOWN_SECONDS=1800
RISK_BLOCK_ON_BALANCE_MISMATCH=true
RISK_BLOCK_ON_PARTIAL_FILL=true
RISK_BLOCK_ON_OPEN_ORDER=true
RISK_BLOCK_ON_OPEN_POSITION=true
RISK_MAX_POSITION_RATIO_PERCENT=20
RISK_MAX_ORDER_KRW=30000
RISK_VOLATILITY_WINDOW=5
RISK_VOLATILITY_BLOCK_PERCENT=2
RISK_MIN_VOLUME_KRW=0
RISK_MIN_CURRENT_1M_VOLUME_KRW=30000000
RISK_MIN_AVG_5M_VOLUME_KRW=50000000
RISK_REQUIRE_COMPLETED_CANDLE=true
RISK_REQUIRE_ORDER_CHANCE_SUCCESS=true
